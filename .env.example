# Pyramid — Environment Variables Template
# Copy this file to .env.local and fill in values for local dev.
# NEVER commit .env.local or any file containing real keys.
# Store real values in: 1Password / GitHub Secrets / Xcode build settings

# ─── Supabase Dev ────────────────────────────────────────────────────────────
SUPABASE_URL_DEV=https://qvmzmeizluqcdkcjsqyd.supabase.co
SUPABASE_ANON_KEY_DEV=           # anon/public JWT — safe for iOS client
SUPABASE_SERVICE_ROLE_KEY_DEV=   # service role JWT — Edge Functions only, never iOS client
SUPABASE_DB_PASSWORD_DEV=        # DB password — never in source, use Supabase CLI

# ─── Supabase Staging ────────────────────────────────────────────────────────
SUPABASE_URL_STAGING=            # not yet provisioned
SUPABASE_ANON_KEY_STAGING=
SUPABASE_SERVICE_ROLE_KEY_STAGING=
SUPABASE_DB_PASSWORD_STAGING=

# ─── Supabase Prod ───────────────────────────────────────────────────────────
SUPABASE_URL_PROD=https://cracvbokmvryhhclzxxw.supabase.co
SUPABASE_ANON_KEY_PROD=          # anon/public JWT — safe for iOS client
SUPABASE_SERVICE_ROLE_KEY_PROD=  # service role JWT — Edge Functions only, NEVER iOS client
SUPABASE_DB_PASSWORD_PROD=       # DB password — never in source

# ─── API-Football ────────────────────────────────────────────────────────────
API_FOOTBALL_KEY=                # RapidAPI key — Edge Functions only, never iOS client

# ─── SSO / OAuth Providers ──────────────────────────────────────────────────
# Required for Apple / Google sign-in. Configure in Supabase Dashboard → Auth → Providers.
# For local dev (supabase start), also add to supabase/config.toml [auth.external.*].
APPLE_CLIENT_ID=                 # Apple Service ID (e.g. com.pyramid.app.signin)
APPLE_SECRET=                    # Apple private key (p8 contents)
GOOGLE_CLIENT_ID=                # Google OAuth 2.0 Client ID
GOOGLE_SECRET=                   # Google OAuth 2.0 Client Secret

# ─── iOS Build (Xcode build settings / xcconfig) ─────────────────────────────
# In Xcode: use a Config.xcconfig per scheme (Debug=dev, Release=prod)
# SUPABASE_URL=$(SUPABASE_URL_DEV)
# SUPABASE_ANON_KEY=$(SUPABASE_ANON_KEY_DEV)
