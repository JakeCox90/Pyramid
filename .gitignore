build/
DerivedData/
*.ipa
*.dSYM.zip
*.dSYM
*.xcconfig.local

# ─── Swift Package Manager ───────────────────────────────────────────────────
.build/
.swiftpm/

# ─── macOS ───────────────────────────────────────────────────────────────────
.DS_Store
*.swp

